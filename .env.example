# Скопируй в .env и заполни. .env в git не коммитится.

MAIL_PROVIDER=gmail

# --- Gmail (локальный тест) ---
# App Password, НЕ пароль от аккаунта: https://myaccount.google.com/apppasswords
# Требует включённой 2FA. Вводить без пробелов.
GMAIL_LOGIN=you@gmail.com
GMAIL_APP_PASSWORD=

# --- Внутренний контур ---
# Имена переменных совпадают с b2c_daily_researcher_qwen
SBER_IMAP_HOST=imap.sberbank.ru
D_LOGIN=
MAIL_PASS=

KMP_DUPLICATE_LIB_OK=TRUE

# ВКЛЮЧЕНИЕ ТРЕССИРОВКИ
LANGCHAIN_TRACING_V2=true

# КЛЮЧ И ENDPOINT ДЛЯ LANGSMITH
LANGCHAIN_API_KEY=
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# НАЗВАНИЕ ПРОЕКТА (опционально)
LANGCHAIN_PROJECT="mail-agent"

OPENROUTER_API_KEY=